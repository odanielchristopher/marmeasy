generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  email    String @unique
  password String

  clients           Client[]
  products          Product[]
  productCategories ProductCategory[]
  ingredients       Ingredient[]
  Order             Order[]
  OrderItem         OrderItem[]

  @@map("users")
}

model Client {
  id       String     @id @default(uuid()) @db.Uuid
  userId   String     @map("user_id") @db.Uuid
  name     String
  phone    String?
  address  String?
  type     ClientType
  document String?    @unique
  balance  Float      @default(0)

  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  Order Order[]

  @@map("clients")
}

enum ClientType {
  FISICO
  JURIDICO
}

model Product {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  name        String
  description String?
  imagePath   String?
  price       Float
  categoryId  String?      @map("product_category_id") @db.Uuid
  ingredients Ingredient[] @relation("product_ingredient")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("products")
}

model ProductCategory {
  id       String    @id @default(uuid()) @db.Uuid
  userId   String    @map("user_id") @db.Uuid
  name     String
  icon     String
  products Product[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name]) // Adicionando a restrição de unicidade composta
  @@map("product_category")
}

model Ingredient {
  id       String    @id @default(uuid()) @db.Uuid
  userId   String    @map("user_id") @db.Uuid
  name     String
  icon     String
  products Product[] @relation("product_ingredient")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ingredients")
}

model Order {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  clientId   String      @map("client_id") @db.Uuid
  date       DateTime    @default(now())
  totalValue Float       @default(0)
  discount   Float       @default(0)
  status     OrderStatus @default(PENDING)
  items      OrderItem[]

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  ingredients String[]
  quantity    Int      @default(1)
  unitPrice   Float
  total       Float    @default(0)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@map("order_items")
}

enum OrderStatus {
  PENDING
  PAID
}
