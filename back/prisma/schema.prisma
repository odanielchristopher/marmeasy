generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  email    String @unique
  password String

  @@map("users")
}

model Client {
  id       String     @id @default(uuid()) @db.Uuid
  name     String
  phone    String
  address  String
  type     ClientType
  document String     @unique
  balance  Float      @default(0)

  @@map("clients")
}

enum ClientType {
  FISICO
  JURIDICO
}
